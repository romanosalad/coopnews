{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/newsletter/cron?day=tuesday",
      "schedule": "0 10 * * 2"
    },
    {
      "path": "/api/newsletter/cron?day=thursday",
      "schedule": "0 10 * * 4"
    }
  ]
}
